{
  "buildCommand": "pnpm install --frozen-lockfile && pnpm run build --filter @workspace/file-share",
  "outputDirectory": "artifacts/file-share/dist/public",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "installCommand": "corepack enable && corepack prepare pnpm@latest --activate"
}
